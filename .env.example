# Server
PORT=3000
PUBLIC_BASE_URL=https://example.ngrok-free.app
DEFAULT_TIME_ZONE=America/New_York
GARDEN_DEV_MODE=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=https://api.openai.com/v1
# Set true if your Twilio media URLs are private and should be downloaded
# then sent to OpenAI as data URLs.
OPENAI_INLINE_MEDIA=false

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_VALIDATE_SIGNATURE=false

# Local storage and reminders
DATA_DIR=data
REMINDER_INTERVAL_MS=60000
DISABLE_REMINDER_WORKER=false
